{
  "name": "atlas-orm-migrations",
  "version": "0.3.0",
  "private": true,
  "description": "Proyecto Atlas - Backend NestJS con migraciones, seeds y primeros endpoints de negocio (Fase 1: usuarios).",
  "license": "UNLICENSED",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "type-check": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint --config eslint.config.mjs \"src/**/*.ts\" \"test/**/*.ts\" \"scripts/**/*.ts\"",
    "lint:fix": "eslint --config eslint.config.mjs \"src/**/*.ts\" \"test/**/*.ts\" \"scripts/**/*.ts\" --fix",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\" \"scripts/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"test/**/*.ts\" \"scripts/**/*.ts\"",
    "db:migration:create": "tsx scripts/create-migration.ts",
    "db:migration:up": "tsx src/database/migrate.ts up",
    "db:migration:down": "tsx src/database/migrate.ts down",
    "db:migration:status": "tsx src/database/migrate.ts status",
    "db:seed:create": "tsx scripts/create-seeder.ts",
    "db:seed:up": "tsx src/database/seed.ts up",
    "db:seed:down": "tsx src/database/seed.ts down",
    "db:seed:status": "tsx src/database/seed.ts status",
    "db:seed:reseed": "tsx src/database/seed.ts reseed",
    "db:seed:prod": "tsx src/database/seed.ts up --profile=production",
    "db:seed:dev": "tsx src/database/seed.ts up --profile=development",
    "db:seed:demo": "tsx src/database/seed.ts up --profile=demo",
    "db:seed:test": "tsx src/database/seed.ts up --profile=test",
    "db:seed:status:prod": "tsx src/database/seed.ts status --profile=production",
    "db:seed:status:dev": "tsx src/database/seed.ts status --profile=development",
    "db:seed:status:demo": "tsx src/database/seed.ts status --profile=demo",
    "db:seed:status:test": "tsx src/database/seed.ts status --profile=test",
    "db:seed:reseed:dev": "tsx src/database/seed.ts reseed --profile=development",
    "db:seed:reseed:demo": "tsx src/database/seed.ts reseed --profile=demo",
    "db:seed:reseed:test": "tsx src/database/seed.ts reseed --profile=test",
    "check:seed-profiles": "tsx scripts/check-seed-profile.ts",
    "check:db-privileges": "tsx scripts/check-db-privileges.ts",
    "db:roles:bootstrap": "tsx scripts/bootstrap-db-roles.ts",
    "check:overfetching": "tsx scripts/check-overfetching.ts",
    "check:file-size": "tsx scripts/check-file-size.ts",
    "check:read-api-views": "tsx scripts/check-read-api-views.ts",
    "db:seed:verify-prod-idempotency": "tsx scripts/verify-prod-seed-idempotency.ts",
    "db:extract-read-workload": "tsx scripts/extract-read-workload.ts",
    "db:capture-query-baseline": "tsx scripts/capture-query-baseline.ts",
    "dev:jwt": "tsx scripts/create-dev-jwt.ts",
    "hash-password": "tsx scripts/hash-password.ts",
    "start": "node dist/src/main.js",
    "start:dev": "node scripts/dev-build-and-start.mjs",
    "test": "jest --config jest.config.cjs",
    "test:unit": "jest --config jest.config.cjs --testPathPattern=test/unit",
    "test:unit:randomized": "jest --config jest.config.cjs --testPathPattern=test/unit --randomize",
    "test:e2e": "jest --config jest.config.cjs --testPathPattern=test/e2e",
    "test:watch": "jest --config jest.config.cjs --watch",
    "test:coverage": "jest --config jest.config.cjs --coverage",
    "docs:openapi": "tsc -p tsconfig.json && node dist/scripts/generate-openapi.js",
    "check:no-env-file": "tsx scripts/check-no-env-file.ts",
    "check:smoke-results-untracked": "tsx scripts/check-no-tracked-smoke-results.ts",
    "smoke": "tsx scripts/smoke/index.ts",
    "db:seed:verify-graph": "tsx scripts/verify-seed-graph-integrity.ts",
    "db:context:load": "tsx scripts/load-multidomain-context.ts",
    "db:context:validate": "tsx scripts/load-multidomain-context.ts --dry-run",
    "smoke:sessions": "tsx scripts/smoke/sessions.smoke.ts",
    "smoke:catalog": "tsx scripts/smoke/catalog.smoke.ts",
    "smoke:runtime": "tsx scripts/smoke/runtime.smoke.ts",
    "smoke:core": "tsx scripts/smoke/core.smoke.ts",
    "smoke:risk-telemetry": "tsx scripts/smoke/risk-telemetry.smoke.ts",
    "smoke:auth": "tsx scripts/smoke/auth.smoke.ts",
    "start:dev:tsx": "tsx watch src/main.ts",
    "start:watch:build": "tsc -w -p tsconfig.json",
    "smoke:events": "tsx scripts/smoke/events.smoke.ts",
    "smoke:notifications": "tsx scripts/smoke/notifications.smoke.ts",
    "stress:notifications": "tsx scripts/stress/notifications.stress.ts",
    "start:prod": "tsc -p tsconfig.json && node dist/src/main.js",
    "env:doctor": "tsx scripts/env-doctor.ts",
    "crypto:reencrypt-pii": "tsx scripts/reencrypt-pii-to-envelope.ts",
    "crypto:reencrypt-pii:dry-run": "tsx scripts/reencrypt-pii-to-envelope.ts --dry-run",
    "clean:legacy-configs": "node scripts/cleanup-legacy-configs.cjs",
    "mock:providers": "tsx tools/external-providers-mock-server/server.ts",
    "test:external-providers": "jest --config jest.config.cjs --testPathPattern=test/unit/external-data",
    "test:external-providers:smoke": "tsx scripts/smoke/external-providers.smoke.ts",
    "test:external-providers:errors": "tsx scripts/smoke/external-providers-errors.smoke.ts",
    "smoke:external-providers": "tsx scripts/smoke/external-providers.smoke.ts",
    "smoke:external-providers:errors": "tsx scripts/smoke/external-providers-errors.smoke.ts",
    "test:e2e:external-providers": "tsx scripts/smoke/external-providers.smoke.ts && tsx scripts/smoke/external-providers-errors.smoke.ts",
    "audit:external-providers": "yarn type-check && yarn lint && yarn format:check && yarn test",
    "smoke:external-providers:all": "yarn smoke:external-providers && yarn smoke:external-providers:errors",
    "audit:external-providers:deep": "yarn type-check && yarn lint && yarn format:check && yarn test && yarn build",
    "audit:external-providers:prod-gates": "yarn audit:external-providers:deep && yarn smoke:external-providers:all",
    "audit:external-providers:go-live": "yarn audit:external-providers:deep && yarn smoke:external-providers:all",
    "audit:external-providers:v5": "yarn audit:external-providers:deep",
    "smoke:external-providers:governance": "tsx scripts/smoke/external-providers-governance.smoke.ts",
    "audit:external-providers:v6": "yarn audit:external-providers:deep && yarn smoke:external-providers:governance",
    "audit:external-providers:idempotency": "yarn type-check && yarn lint && yarn format:check && yarn test",
    "audit:external-providers:v7": "yarn type-check && yarn lint && yarn format:check && yarn test && yarn build",
    "audit:external-providers:quality-10": "yarn audit:external-providers:v7 && yarn smoke:external-providers:governance",
    "smoke:internal-rbac": "tsx scripts/smoke/internal-rbac.smoke.ts",
    "smoke:frontend-contract": "tsx scripts/smoke/frontend-contract.smoke.ts"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.6",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.6",
    "@nestjs/platform-express": "^11.1.27",
    "@nestjs/sequelize": "^11.0.0",
    "@nestjs/swagger": "^11.4.5",
    "@nestjs/throttler": "^6.5.0",
    "argon2": "^0.41.1",
    "dotenv": "^17.4.2",
    "helmet": "^8.2.0",
    "ioredis": "^5.4.1",
    "joi": "^18.2.3",
    "js-yaml": "^4.1.0",
    "jsonwebtoken": "^9.0.3",
    "mongodb": "^7.5.0",
    "pg": "^8.16.3",
    "pg-hstore": "^2.3.4",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "sequelize": "^6.37.7",
    "sequelize-typescript": "^2.1.6",
    "swagger-ui-express": "^5.0.1",
    "umzug": "^3.8.2",
    "zod": "^4.0.17"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@nestjs/testing": "^11.1.6",
    "@types/jest": "^29.5.14",
    "@types/js-yaml": "^4.0.9",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.3.0",
    "@types/supertest": "^7.2.0",
    "@types/validator": "^13.15.10",
    "@typescript-eslint/eslint-plugin": "^8.19.1",
    "@typescript-eslint/parser": "^8.19.1",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^9.1.0",
    "jest": "^29.7.0",
    "prettier": "^3.4.2",
    "supertest": "^7.2.2",
    "ts-jest": "^29.2.5",
    "tsx": "^4.20.5",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "resolutions": {
    "js-yaml": "^4.2.0",
    "lodash": "^4.18.0",
    "multer": "^2.2.0",
    "uuid": "^11.1.1"
  },
  "packageManager": "yarn@1.22.22"
}
