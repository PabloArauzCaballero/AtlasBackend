@startuml AtlasUserIntelligenceFraudSchemaV5_2_1
' =====================================================================
' PROYECTO ATLAS - User Intelligence & Fraud Risk Schema
' Version: 5.2.1 (roadmap reclasificado como YAML no ORM)
' Enfoque: informacion alrededor del usuario, identidad, comportamiento,
'          dispositivos, sesiones, fraude, privacidad, contexto,
'          observaciones, features y evaluacion de riesgo.
'
' IMPORTANTE:
'  - Esta version NO modela credito, prestamos, cuotas, pagos, MDR,
'    cobranza ni limites de credito.
'  - Construye la capa base de inteligencia del usuario que despues
'    alimenta productos financieros u otros flujos.
'
' Cambios v5.1 -> v5.2:
'  [G1] RiskAssessmentRun ahora soporta subject flexible:
'       customer | session | onboarding_flow | device | checkout_context.
'       customer_id deja de ser obligatorio para permitir evaluar riesgo
'       antes de crear Customer.
'  [G2] Se agrega RiskAssessmentContext como snapshot neutral de POS/
'       checkout: merchant snapshot, categoria, monto, basket anomaly y
'       comportamiento ante pago inicial, sin modelar credito ni pagos.
'  [G3] WatchlistEntry agrega country_code y regla de alcance:
'       global -> sin tenant/pais; country -> country_code requerido;
'       tenant -> _tenant_id requerido.
'  [G4] ObservationDefinition, AttributeDefinition y FeatureDefinition
'       agregan gobernanza de uso: allowed_for_credit_decision,
'       allowed_for_fraud_decision, legal_review_status,
'       prohibited_reason_code, fairness_review_required.
'  [G5] Se aclara versioned + append-only como append-only practico:
'       solo se permite cerrar vigencia tecnica con valid_until /
'       superseded_by_version_id; el contenido historico no se reescribe.
'  [G6] Indices y notas actualizadas para subject flexible, POS context
'       y variables sensibles/prohibidas.
'  [G7] ImplementationPhase y EntityBuildScope se reclasifican como
'       configuracion YAML externa. NO son tablas SQL y el ORM NO debe
'       generar migraciones ni entidades persistentes para ellas.
' =====================================================================

skinparam classAttributeIconSize 0
skinparam classFontStyle bold
skinparam packageStyle rectangle
skinparam linetype ortho
skinparam shadowing false
skinparam class {
  BackgroundColor #FEFDF9
  BorderColor #5F5E5A
  ArrowColor #5F5E5A
}
skinparam stereotype {
  CBackgroundColor<<platform-root>> #E5E5E5
  CBackgroundColor<<core>> #EEEDFE
  CBackgroundColor<<append-only>> #E1F5EE
  CBackgroundColor<<event>> #F3F7FA
  CBackgroundColor<<versioned>> #FAEEDA
  CBackgroundColor<<snapshot>> #E9F3FF
  CBackgroundColor<<projection>> #F7E9F7
  CBackgroundColor<<catalog>> #FFF4D6
  CBackgroundColor<<platform-shared>> #FFE9DC
  CBackgroundColor<<privacy>> #FCEBEB
  CBackgroundColor<<derived>> #EDF8E9
  CBackgroundColor<<case>> #FCE9F2
  CBackgroundColor<<quality>> #EAF7FF
  CBackgroundColor<<roadmap>> #EEF2FF
  CBackgroundColor<<yaml-config>> #E8F4FF
  CBackgroundColor<<no-orm>> #FFE6E6
}

hide empty members

' =====================================================================
' TAXONOMIA DE ESTEREOTIPOS
' =====================================================================
' platform-root    - Entidad raiz de plataforma. No tiene _tenant_id.
' core             - Operacional mutable tenant-scoped. Campos estandar
'                    completos: _id, _tenant_id, _created_at,
'                    _updated_at, _deleted.
' append-only      - Historial inmutable. No update/delete logico.
'                    Solo _id, _tenant_id (si aplica), _created_at.
' event            - Append-only de alto volumen. Particionar y archivar.
' versioned        - Cambios por nueva version, no sobrescritura.
'                    valid_from/valid_until o status workflow.
' versioned + append-only (combo) - Append-only practico con vigencia.
'                    Cada cambio = fila nueva con valid_from. Se permite
'                    cerrar vigencia tecnica de la version anterior solo
'                    con valid_until / superseded_by_version_id; el
'                    contenido historico no se reescribe.
' snapshot         - Foto congelada inmutable para auditoria.
' projection       - Cache derivado. Source of truth vive en eventos.
'                    Debe poder reconstruirse desde la fuente.
' catalog          - Datos de referencia o definiciones.
' platform-shared  - Cross-tenant, sin _tenant_id.
' privacy          - Dato sensible con reglas de minimizacion/retencion.
' derived          - Calculado desde otras fuentes; recalculable.
' case             - Gestion operativa de revision/investigacion.
' quality          - Reglas y hallazgos de calidad de datos.
' roadmap          - Catalogo de planificacion (MVP/Fase 1/Fase 2).
' yaml-config      - Configuracion externa en YAML versionada en Git.
'                    NO se persiste como tabla SQL.
' no-orm           - El ORM no debe crear entidad, migracion ni tabla.
'                    Se consume por parser/config loader de aplicacion.
' =====================================================================

' =====================================================================
' ENUMS RECURRENTES (documentados, no son tablas)
' =====================================================================
' risk_dimension:    fraud | identity | device | behavior |
'                    contactability | consistency | privacy | data_quality |
'                    checkout_context
'
' watchlist scope:   global | country | tenant
' watchlist country: country_code requerido solo cuando scope = country
'
' lifecycle_status (Customer):
'                    pending_kyc | active | suspended | blocked |
'                    closed_by_user | deleted_by_compliance
'
' storage_mode (SensitiveFieldRule):
'                    plain | hash | hash_encrypted_last4 |
'                    encrypted | redacted | snapshot_only | none
'
' DataProviderResponse.payload_storage_strategy:
'                    inline_full | inline_redacted | s3_raw | hashed_only
' =====================================================================

' =====================================================================
' PACKAGE: Plataforma, usuarios internos, proveedores y retencion
' =====================================================================
package "01 Plataforma" as platform {

  class Tenant <<platform-root>> {
    + _id : BIGSERIAL <<PK>>
    + tenant_code : VARCHAR(60) <<UNIQUE>>
    + legal_name : VARCHAR(180)
    + country_code : VARCHAR(3)
    + status : VARCHAR(40)
    + _created_at : TIMESTAMPTZ
    + _updated_at : TIMESTAMPTZ
    + _deleted : BOOLEAN
  }

  class PlatformUser <<platform-root>> {
    + _id : BIGSERIAL <<PK>>
    + user_code : VARCHAR(60) <<UNIQUE>>
    + full_name : VARCHAR(180)
    + email : VARCHAR(180) <<UNIQUE>>
    + role_code : VARCHAR(80)
    + status : VARCHAR(40)
    + _created_at : TIMESTAMPTZ
    + _updated_at : TIMESTAMPTZ
    + _deleted : BOOLEAN
  }

  class InternalUser <<core>> {
    + _id : BIGSERIAL <<PK>>
    + _tenant_id : BIGINT <<FK>>
    + user_code : VARCHAR(60) <<UNIQUE per tenant>>
    + full_name : VARCHAR(180)
    + email : VARCHAR(180)
    + role_code : VARCHAR(80)
    + status : VARCHAR(40)
    + _created_at : TIMESTAMPTZ
    + _updated_at : TIMESTAMPTZ
    + _deleted : BOOLEAN
  }

  class RetentionPolicy <<catalog, platform-shared>> {
    + _id : BIGSERIAL <<PK>>
    + policy_code : VARCHAR(80) <<UNIQUE>>
    + applies_to : VARCHAR(80)
    + retention_days : INTEGER
    + post_retention_action : VARCHAR(40)
    + legal_basis : VARCHAR(180)
    + description : TEXT
    + is_active : BOOLEAN
    + _created_at : TIMESTAMPTZ
    + _updated_at : TIMESTAMPTZ
  }

  class ImplementationPhase <<yaml-config, no-orm, roadmap>> {
    + yaml_file : config/roadmap/implementation_phases.yaml
    + phase_code : string <<YAML key, unique>>
    + phase_name : string
    + phase_order : integer
    + objective : string
    + entry_criteria : string
    + exit_criteria : string
    + is_active : boolean
  }

  class EntityBuildScope <<yaml-config, no-orm, roadmap>> {
    + yaml_file : config/roadmap/entity_build_scope.yaml
    + entity_name : string
    + package_name : string
    + phase_code : string <<YAML FK to ImplementationPhase.phase_code>>
    + priority : string
    + implementation_status : string
    + rationale : string
    + notes : string
  }

  class DataProvider <<catalog, platform-shared>> {
    + _id : BIGSERIAL <<PK>>
    + provider_code : VARCHAR(80) <<UNIQUE>>
    + provider_name : VARCHAR(180)
    + provider_type : VARCHAR(60)
    + reliability_score : NUMERIC(5,2)
    + supports_retro_data : BOOLEAN
    + default_retention_policy_id : BIGINT <<FK?>>
    + is_active : BOOLEAN
    + _created_at : TIMESTAMPTZ
    + _updated_at : TIMESTAMPTZ
  }

  class DataProviderRequest <<append-only>> {
    + _id : BIGSERIAL <<PK>>
    + _tenant_id : BIGINT <<FK>>
    + provider_id : BIGINT <<FK>>
    + customer_id : BIGINT <<FK?>>
    + risk_assessment_run_id : BIGINT <<FK?>>
    + consent_id : BIGINT <<FK?>>
    + request_type : VARCHAR(80)
    + provider_request_ref : VARCHAR(160)
    + request_payload_hash : VARCHAR(128)
    + idempotency_key : VARCHAR(128)
    + response_status : VARCHAR(40)
    + response_code : VARCHAR(80)
    + latency_ms : INTEGER
    + requested_at : TIMESTAMPTZ
    + responded_at : TIMESTAMPTZ
    + _created_at : TIMESTAMPTZ
  }

  class DataProviderResponse <<append-only, privacy>> {
    + _id : BIGSERIAL <<PK>>
    + _tenant_id : BIGINT <<FK>>
    + provider_request_id : BIGINT <<FK>>
    + payload_storage_strategy : VARCHAR(40)
    + response_payload_json : JSONB
    + redacted_payload_json : JSONB
    + raw_payload_s3_key : TEXT
    + response_hash : VARCHAR(128)
    + normalized_payload_json : JSONB
    + contains_sensitive_data : BOOLEAN
    + retention_policy_id : BIGINT <<FK?>>
    + retention_until : DATE
    + _created_at : TIMESTAMPTZ
  }
}

