# Desarrollo local: mantener en development. Producción debe usar .env.production real.
NODE_ENV=development
APP_PORT=3005
API_PREFIX=api/v1
CORS_ORIGINS=http://localhost:3000,http://localhost:5273
INTERNAL_FRONTEND_ORIGIN=http://localhost:5273

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=atlas
DB_USER=postgres
DB_PASSWORD=postgres
DB_SCHEMA=public
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=true

# Seeds / reset de datos de prueba.
# DATABASE_CLEAN_BEFORE_SEED=true borra los datos de aplicación antes de `yarn db:seed:up`.
# Preserva SequelizeMeta, limpia SequelizeDataSeeders y recarga todos los datos semilla.
DATABASE_CLEAN_BEFORE_SEED=false
DATABASE_CLEAN_ALLOW_PRODUCTION=false
DATABASE_CLEAN_CONFIRM=

# Bootstrap idempotente al arrancar: crea columnas/tablas/vistas de compatibilidad faltantes
# sin borrar datos (ver src/config/configuration.ts). Apagar solo si administras el schema
# exclusivamente por migraciones y prefieres detectar drift en vez de auto-corregirlo.
DATABASE_BOOTSTRAP_ON_STARTUP=true
DATABASE_BOOTSTRAP_FAIL_FAST=true
DATABASE_SEED_PUBLIC_CMS_ON_STARTUP=true

# Auth
# Usuario seed para desarrollo del panel interno: pablo@atlas.internal / Atlas_Pablo#2026!
JWT_ACCESS_TOKEN_SECRET=change-this-secret-with-at-least-32-characters
SYSTEM_TEST_ALLOWED_HOSTS_LOCAL=localhost,127.0.0.1,::1,host.docker.internal
SYSTEM_TEST_ALLOWED_HOSTS_STAGING=staging-api.example.com
SYSTEM_TEST_ALLOWED_HOSTS_PRODUCTION_READONLY=
JWT_ACCESS_TOKEN_EXPIRES_IN=1h

# ATLAS-AUDIT-002: configuración del módulo auth (login/refresh/logout).
AUTH_REFRESH_TOKEN_EXPIRES_IN_DAYS=30
AUTH_MAX_FAILED_LOGIN_ATTEMPTS=5
AUTH_LOCKOUT_MINUTES=15

# ATLAS-AUDIT-023: Redis para rate limiting distribuido. Obligatorio en producción (ver
# src/config/env.ts). En local/desarrollo con una sola instancia puede dejarse vacío: el
# throttler cae a almacenamiento en memoria (correcto solo con una única instancia).
# Ejemplo local: redis://localhost:6379
REDIS_URL=

# API rate limit. Raise API_RATE_LIMIT_MAX only in controlled stress environments.
API_RATE_LIMIT_TTL_MS=60000
API_RATE_LIMIT_MAX=100

# -----------------------------------------------------------------------------
# Notifications core
# -----------------------------------------------------------------------------
# in_app does not require an external provider. It is delivered inside ATLAS.
# External channels are disabled by default to avoid accidental sends.
# Enable each channel by changing provider and setting the provider credentials.
NOTIFICATION_DEFAULT_LOCALE=es-BO
NOTIFICATION_EMAIL_PROVIDER=disabled
NOTIFICATION_PUSH_PROVIDER=disabled
NOTIFICATION_SMS_PROVIDER=disabled
NOTIFICATION_WHATSAPP_PROVIDER=disabled
NOTIFICATION_PHONE_PROVIDER=disabled

# Secret used to encrypt FCM tokens and delivery targets.
# Local: este valor de ejemplo es aceptado solo con NODE_ENV=development/test.
# Producción: usar un secreto real, largo, único y distinto de JWT_ACCESS_TOKEN_SECRET.
NOTIFICATION_TOKEN_ENCRYPTION_KEY=change-this-32-plus-character-key-for-device-tokens

# Provider HTTP behavior for JSON-based adapters/webhooks.
NOTIFICATION_PROVIDER_HTTP_TIMEOUT_MS=15000
NOTIFICATION_PROVIDER_HTTP_RETRIES=1
NOTIFICATION_PROVIDER_HTTP_RETRY_BASE_DELAY_MS=250
# For fintech privacy, default data-only push. Set true only if you intentionally want visible OS notifications.
NOTIFICATION_PUSH_INCLUDE_VISIBLE_NOTIFICATION=false

# Generic webhook fallback used when a channel-specific webhook URL is not set.
# Channel-specific URLs are recommended when testing several channels at once.
NOTIFICATION_WEBHOOK_URL=
NOTIFICATION_EMAIL_WEBHOOK_URL=
NOTIFICATION_PUSH_WEBHOOK_URL=
NOTIFICATION_SMS_WEBHOOK_URL=
NOTIFICATION_WHATSAPP_WEBHOOK_URL=
NOTIFICATION_PHONE_WEBHOOK_URL=

# -----------------------------------------------------------------------------
# Email providers
# NOTIFICATION_EMAIL_PROVIDER=disabled | resend | sendgrid | gmail_api | webhook
# -----------------------------------------------------------------------------
RESEND_API_KEY=
RESEND_FROM_EMAIL=
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
GMAIL_FROM_EMAIL=

# -----------------------------------------------------------------------------
# Push providers
# NOTIFICATION_PUSH_PROVIDER=disabled | fcm | webhook
# -----------------------------------------------------------------------------
FCM_PROJECT_ID=
FCM_CLIENT_EMAIL=
# Use \n escaped line breaks when storing this in .env.
FCM_PRIVATE_KEY=

# -----------------------------------------------------------------------------
# SMS provider
# NOTIFICATION_SMS_PROVIDER=disabled | twilio | webhook
# -----------------------------------------------------------------------------
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_SMS_FROM=

# -----------------------------------------------------------------------------
# WhatsApp providers
# NOTIFICATION_WHATSAPP_PROVIDER=disabled | meta_cloud | twilio | webhook
# -----------------------------------------------------------------------------
TWILIO_WHATSAPP_FROM=
META_WHATSAPP_TOKEN=
META_WHATSAPP_PHONE_NUMBER_ID=
# Optional fallback template for Meta WhatsApp Cloud API. Prefer explicit template mapping by event/template_code.
META_WHATSAPP_DEFAULT_TEMPLATE_NAME=
META_WHATSAPP_DEFAULT_TEMPLATE_LANGUAGE=es

# -----------------------------------------------------------------------------
# Phone/call provider
# NOTIFICATION_PHONE_PROVIDER=disabled | webhook
# Real phone-call vendors should be connected behind the webhook adapter first,
# unless a first-class provider adapter is implemented later.
# -----------------------------------------------------------------------------

# External Data Providers — Fase 1/2/3
EXTERNAL_PROVIDERS_MOCK_BASE_URL=http://localhost:4010/mock
SEGIP_MODE=mock_local
SEGIP_MOCK_BASE_URL=http://localhost:4010/mock/segip
SEGIP_BASE_URL=
SEGIP_CLIENT_ID=
SEGIP_CLIENT_SECRET=
INFOCENTER_MODE=mock_local
INFOCENTER_MOCK_BASE_URL=http://localhost:4010/mock/infocenter
INFOCENTER_BASE_URL=
INFOCENTER_CLIENT_ID=
INFOCENTER_CLIENT_SECRET=
INFOCENTER_ALLOW_AUTOMATIC_QUERIES=false
INFOCENTER_DEFAULT_BLOCK_BY_COST=true
QR_GENERIC_MODE=mock_local
QR_GENERIC_MOCK_BASE_URL=http://localhost:4010/mock/qr
BANKING_GENERIC_MODE=mock_local
BANKING_GENERIC_MOCK_BASE_URL=http://localhost:4010/mock/banking
TELCO_GENERIC_MODE=mock_local
TELCO_GENERIC_MOCK_BASE_URL=http://localhost:4010/mock/telco
FACEBOOK_META_MODE=mock_local
FACEBOOK_META_MOCK_BASE_URL=http://localhost:4010/mock/facebook
WHATSAPP_GENERIC_MODE=mock_local
WHATSAPP_GENERIC_MOCK_BASE_URL=http://localhost:4010/mock/whatsapp
DIGITAL_TRUST_GENERIC_MODE=mock_local
DIGITAL_TRUST_GENERIC_MOCK_BASE_URL=http://localhost:4010/mock/digital-trust
MOCK_PROVIDERS_PORT=4010
MOCK_PROVIDERS_DEFAULT_LATENCY_MS=300
MOCK_PROVIDERS_SCENARIO=happy_path

# External Data Providers — hardening v3
EXTERNAL_PROVIDER_CIRCUIT_BREAKER_ENABLED=true
EXTERNAL_PROVIDER_CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
EXTERNAL_PROVIDER_CIRCUIT_BREAKER_WINDOW_MS=600000

# External providers v4 resilience / long-term controls
EXTERNAL_PROVIDER_CACHE_TTL_SECONDS=0
EXTERNAL_FEATURE_MAX_AGE_HOURS=168
EXTERNAL_PROVIDER_CIRCUIT_BREAKER_ENABLED=true
EXTERNAL_PROVIDER_CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
EXTERNAL_PROVIDER_CIRCUIT_BREAKER_WINDOW_MS=600000

# External providers v5 governance
EXTERNAL_PROVIDER_PROD_GATE_SANITIZATION_SAMPLE=100
EXTERNAL_PROVIDER_SLA_FAILURE_WARN_PERCENT=10
EXTERNAL_PROVIDER_SLA_P95_LATENCY_WARN_MS=5000


# -----------------------------------------------------------------------------
# Remote append-only sync de Archivo.log hacia MongoDB
# -----------------------------------------------------------------------------
# Configura MONGO_DB_URL_CONNECTION solo en .env local real o secret manager.
# Si queda vacio, el modulo no intenta conectar a Mongo.
MONGO_DB_URL_CONNECTION=
MONGO_LOGS_DB_NAME=atlas_logs
MONGO_LOGS_COLLECTION=archivo_log_updates
LOG_SYNC_FILE_PATH=Archivo.log
LOG_SYNC_INTERVAL_MS=5000
LOG_SYNC_MAX_CHUNK_BYTES=1000000
LOG_SYNC_IMPORT_EXISTING_ON_FIRST_BOOT=false
LOG_SYNC_MONGO_SERVER_SELECTION_TIMEOUT_MS=5000
LOG_SYNC_FAILURES_BEFORE_PAUSE=3
LOG_SYNC_FAILURE_PAUSE_MS=60000
