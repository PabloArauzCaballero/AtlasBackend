# Copiar a .env.production real en infraestructura/secret manager, nunca commitear secretos reales.
NODE_ENV=production
APP_PORT=3000
API_PREFIX=api/v1
CORS_ORIGINS=https://admin.tudominio.com,https://merchant.tudominio.com
INTERNAL_FRONTEND_ORIGIN=https://admin.tudominio.com

DB_HOST=<postgres-host>
DB_PORT=5432
DB_NAME=atlas
DB_USER=<postgres-user>
DB_PASSWORD=<postgres-password>
DB_SCHEMA=public
DB_SSL=true

# Seeds / reset de datos de prueba.
# DATABASE_CLEAN_BEFORE_SEED=true borra los datos de aplicación antes de `yarn db:seed:up`.
# Preserva SequelizeMeta, limpia SequelizeDataSeeders y recarga todos los datos semilla.
DATABASE_CLEAN_BEFORE_SEED=false
DATABASE_CLEAN_ALLOW_PRODUCTION=false
DATABASE_CLEAN_CONFIRM=

# Producción: no usar valores de ejemplo y no reutilizar el mismo secreto entre variables.
JWT_ACCESS_TOKEN_SECRET=<minimo-32-caracteres-aleatorio-unico>
JWT_ACCESS_TOKEN_EXPIRES_IN=1h
NOTIFICATION_TOKEN_ENCRYPTION_KEY=<otro-secreto-minimo-32-caracteres-aleatorio-unico>

# Obligatorio en producción para rate limiting distribuido multiinstancia.
REDIS_URL=redis://<usuario>:<password>@<host>:6379
API_RATE_LIMIT_TTL_MS=60000
API_RATE_LIMIT_MAX=100

# Swagger apagado por defecto en producción. Activar solo detrás de VPN/IP allowlist.
API_DOCS_ENABLED=false

AUTH_REFRESH_TOKEN_EXPIRES_IN_DAYS=30
AUTH_MAX_FAILED_LOGIN_ATTEMPTS=5
AUTH_LOCKOUT_MINUTES=15

NOTIFICATION_DEFAULT_LOCALE=es-BO
NOTIFICATION_EMAIL_PROVIDER=disabled
NOTIFICATION_PUSH_PROVIDER=disabled
NOTIFICATION_SMS_PROVIDER=disabled
NOTIFICATION_WHATSAPP_PROVIDER=disabled
NOTIFICATION_PHONE_PROVIDER=disabled

NOTIFICATION_PROVIDER_HTTP_TIMEOUT_MS=15000
NOTIFICATION_PROVIDER_HTTP_RETRIES=1
NOTIFICATION_PROVIDER_HTTP_RETRY_BASE_DELAY_MS=250
NOTIFICATION_PUSH_INCLUDE_VISIBLE_NOTIFICATION=false

NOTIFICATION_WEBHOOK_URL=
NOTIFICATION_EMAIL_WEBHOOK_URL=
NOTIFICATION_PUSH_WEBHOOK_URL=
NOTIFICATION_SMS_WEBHOOK_URL=
NOTIFICATION_WHATSAPP_WEBHOOK_URL=
NOTIFICATION_PHONE_WEBHOOK_URL=

RESEND_API_KEY=
RESEND_FROM_EMAIL=
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
GMAIL_FROM_EMAIL=

FCM_PROJECT_ID=
FCM_CLIENT_EMAIL=
FCM_PRIVATE_KEY=

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_SMS_FROM=
TWILIO_WHATSAPP_FROM=

META_WHATSAPP_TOKEN=
META_WHATSAPP_PHONE_NUMBER_ID=
META_WHATSAPP_DEFAULT_TEMPLATE_NAME=
META_WHATSAPP_DEFAULT_TEMPLATE_LANGUAGE=es

# External Data Providers — producción debe usar sandbox/production con credenciales reales.
EXTERNAL_PROVIDERS_MOCK_BASE_URL=
SEGIP_MODE=disabled
SEGIP_BASE_URL=
SEGIP_CLIENT_ID=
SEGIP_CLIENT_SECRET=
INFOCENTER_MODE=disabled
INFOCENTER_BASE_URL=
INFOCENTER_CLIENT_ID=
INFOCENTER_CLIENT_SECRET=
INFOCENTER_ALLOW_AUTOMATIC_QUERIES=false
INFOCENTER_DEFAULT_BLOCK_BY_COST=true
QR_GENERIC_MODE=disabled
BANKING_GENERIC_MODE=disabled
TELCO_GENERIC_MODE=disabled
FACEBOOK_META_MODE=disabled
WHATSAPP_GENERIC_MODE=disabled
DIGITAL_TRUST_GENERIC_MODE=disabled

# External Data Providers — hardening v3
EXTERNAL_PROVIDER_CIRCUIT_BREAKER_ENABLED=true
EXTERNAL_PROVIDER_CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
EXTERNAL_PROVIDER_CIRCUIT_BREAKER_WINDOW_MS=600000

# External providers v4 resilience / long-term controls
EXTERNAL_PROVIDER_CACHE_TTL_SECONDS=0
EXTERNAL_FEATURE_MAX_AGE_HOURS=168
EXTERNAL_PROVIDER_CIRCUIT_BREAKER_ENABLED=true
EXTERNAL_PROVIDER_CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
EXTERNAL_PROVIDER_CIRCUIT_BREAKER_WINDOW_MS=600000

# External providers v5 governance
EXTERNAL_PROVIDER_PROD_GATE_SANITIZATION_SAMPLE=200
EXTERNAL_PROVIDER_SLA_FAILURE_WARN_PERCENT=5
EXTERNAL_PROVIDER_SLA_P95_LATENCY_WARN_MS=3000

# Remote append-only sync de Archivo.log hacia MongoDB.
# Guardar la URL real en secret manager, no en archivos versionados.
MONGO_DB_URL_CONNECTION=mongodb+srv://<usuario>:<password>@<cluster-host>/?appName=AtlasBackend
MONGO_LOGS_DB_NAME=atlas_logs
MONGO_LOGS_COLLECTION=archivo_log_updates
LOG_SYNC_FILE_PATH=Archivo.log
LOG_SYNC_INTERVAL_MS=5000
LOG_SYNC_MAX_CHUNK_BYTES=1000000
LOG_SYNC_IMPORT_EXISTING_ON_FIRST_BOOT=false
LOG_SYNC_MONGO_SERVER_SELECTION_TIMEOUT_MS=5000
